# SCC Office Dashboard — Backend Environment Variables
# Copy this file to .env and fill in real values before running locally.
# On Replit: add all of these to Replit Secrets. Never commit .env to git.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('YOUR_PASSWORD', 12).then(console.log)"
DASHBOARD_PASSWORD_HASH=$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

# 32+ byte random string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_32_plus_byte_random_hex_string

# ─── OpenClaw Logs ─────────────────────────────────────────────────────────────
OPENCLAW_LOG_PATH=/tmp/openclaw

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Optional — used for cost polling; service degrades gracefully without it
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Pricing (USD per 1M tokens) — update when Anthropic changes pricing
ANTHROPIC_INPUT_PRICE_PER_MILLION_TOKENS=3.00
ANTHROPIC_OUTPUT_PRICE_PER_MILLION_TOKENS=15.00

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_INPUT_PRICE_PER_MILLION_TOKENS=0.075
GEMINI_OUTPUT_PRICE_PER_MILLION_TOKENS=0.30

# ─── Telegram Alerts ──────────────────────────────────────────────────────────
# Optional — alerts are silently skipped if not configured
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Required in production. Set to the exact Replit deployment URL for the frontend.
# Example: https://scc-office-dashboard.replit.app
# Leave blank for local development (localhost origins are allowed automatically).
ALLOWED_ORIGIN=https://REPLACE_WITH_YOUR_REPLIT_APP_URL.replit.app

# ─── Replit ───────────────────────────────────────────────────────────────────
# Provided automatically by Replit runtime. Set manually for local dev.
REPLIT_DB_URL=https://kv.replit.com/v0/REPLACE_WITH_REPLIT_DB_URL
